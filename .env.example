# Deye Microinverter connection settings
# Copy this file to .env and fill in your values.

DEYE_IP=192.168.1.X
DEYE_SERIAL=1234567890

# Optional: rated inverter power in watts (e.g. 300, 600, 1600, 2000)
# If omitted, the tool tries to auto-detect from Modbus register 16.
# DEYE_MICROINVERTER_MAX_POWER=1600
